{
  "name": "frontend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:ci": "vite build --mode production",
    "preview": "wrangler dev",
    "deploy": "wrangler deploy",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:ci": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --output machine --fail-on-warnings",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test:unit": "bun test",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "dependencies": {
    "portfolio-backend": "workspace:*"
  },
  "devDependencies": {
    "@lucide/svelte": "^1.24.0",
    "@sveltejs/adapter-cloudflare": "^7.2.9",
    "@sveltejs/enhanced-img": "^0.11.0",
    "@sveltejs/kit": "^2.69.3",
    "@sveltejs/vite-plugin-svelte": "^7.2.0",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.3",
    "@types/bun": "^1.3.14",
    "@types/serviceworker": "^0.0.199",
    "fontaine": "^0.8.0",
    "mdsvex": "^0.12.7",
    "shiki": "^4.3.1",
    "svelte": "^5.56.5",
    "svelte-check": "^4.7.3",
    "tailwindcss": "^4.3.3",
    "vite": "^8.1.5",
    "vite-imagetools": "^10.0.1"
  }
}
